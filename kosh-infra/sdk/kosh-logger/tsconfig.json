{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "declaration": true,
    "outDir": "dist",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "types": ["node"]
  },
  "include": [
    "*.ts",
    "adapters/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
